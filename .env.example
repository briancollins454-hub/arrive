# ============================================================
# Arrivé — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in values.
# DO NOT commit .env.local to version control.
# ============================================================

# ---- Supabase ----
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Stripe ----
# Get these from https://dashboard.stripe.com/apikeys
# Use pk_test_ keys for development, pk_live_ for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---- Optional ----
# Tax rate as a decimal (e.g. 0.20 = 20%). Defaults to 0.20 if not set.
# VITE_DEFAULT_TAX_RATE=0.20

# ---- Platform Admin ----
# Your email address — the only account that can onboard new hotels.
# This must match the email you use to log in.
VITE_PLATFORM_ADMIN_EMAIL=you@yourdomain.com

# ============================================================
# EDGE FUNCTION SECRETS (server-side only — NOT Vite vars)
# ============================================================
# These are NOT read from this file. Set them on your Supabase
# project so the onboard-hotel / send-invite / accept-invite
# functions can send email and build links:
#
#   supabase secrets set \
#     RESEND_API_KEY=re_xxx \
#     PLATFORM_FROM_EMAIL="no-reply@yourdomain.com" \
#     PLATFORM_FROM_NAME="Arrivé" \
#     APP_URL="https://app.yourdomain.com" \
#     PLATFORM_ADMIN_EMAILS="you@yourdomain.com"
#
# RESEND_API_KEY        — Resend API key (verify a sending domain first)
# PLATFORM_FROM_EMAIL   — From address for invites (must be on a verified domain)
# PLATFORM_FROM_NAME    — Display name for the sender (optional)
# APP_URL               — Public base URL of the app (used to build /invite links)
# PLATFORM_ADMIN_EMAILS — Comma-separated admin allowlist (mirrors platform_admins table)
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are
# injected automatically by Supabase into deployed edge functions.
